# Dataset cache — external files fetched on demand. Re-downloadable via
# `mesmer bench --download`, SHA-verified against each spec. We don't
# vendor them until redistribution terms are confirmed in
# datasets/README.md.
datasets/cache/*.jsonl

# Keep the cache dir in git so `ensure_dataset_cached` can write without
# pre-creating it.
!datasets/cache/.gitkeep

# Run artifacts — one set per `mesmer bench` invocation. They are
# re-producible output, not source. Every run writes a new timestamped
# bundle (top-level summary/README/jsonl + per-trial traces under
# events/ + interactive viz HTML), so committing them by default
# pollutes git history.
#
# When a run IS publication-worthy, force-commit the specific files:
#   git add -f benchmarks/results/20260423T090105Z-v1-*.{jsonl,json,md}
# and (optionally) reference them from the spec's companion README.
results/**
!results/.gitkeep
